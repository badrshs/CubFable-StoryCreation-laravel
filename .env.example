APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

DB_QUEUE_RETRY_AFTER=3900

REGISTRATION_OPEN=true

# TEXT_PROVIDER: openai | gemini | openrouter
# IMAGE_PROVIDER: openai | gemini | openrouter | flow (local flow-image gateway) | grok (xAI direct)
TEXT_PROVIDER=openai
IMAGE_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
# Local flow-image gateway (browser-driven, images only): IMAGE_PROVIDER=flow
FLOW_IMAGE_BASE_URL=http://127.0.0.1:8787
FLOW_IMAGE_API_KEY=
# grok-imagine (supports one reference image) or google-flow
IMAGE_MODEL_FLOW=grok-imagine
# xAI direct (IMAGE_PROVIDER=grok): grok-imagine-image ($0.02) or grok-imagine-image-quality ($0.05)
XAI_API_KEY=
IMAGE_MODEL_GROK=grok-imagine-image
TEXT_MODEL_OPENAI=gpt-5.4
TEXT_MODEL_GEMINI=gemini-2.5-flash
TEXT_MODEL_OPENROUTER=google/gemini-2.5-flash
IMAGE_MODEL_OPENAI=gpt-image-1
IMAGE_MODEL_GEMINI=gemini-2.5-flash-image
# e.g. google/gemini-2.5-flash-image or x-ai/grok-imagine-image-quality
IMAGE_MODEL_OPENROUTER=google/gemini-2.5-flash-image
# Cap reference images per request (Grok Imagine accepts 3; 0 = unlimited)
IMAGE_MAX_REFERENCES=0
# Identity anchor on cover/pages: sheet (generated character sheet) | photo (the original upload)
IMAGE_IDENTITY_REFERENCE=sheet

STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PRICE_CENTS=799
PRICE_CURRENCY=eur
