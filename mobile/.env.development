# Local development. Point EXPO_PUBLIC_API_URL at the machine running
# `composer run dev` (use your LAN IP for a physical device; the Android
# emulator reaches the host at http://10.0.2.2:8000 automatically when unset).
EXPO_PUBLIC_API_URL=http://192.168.0.13:8000
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
